{
    "hosting":  {
                    "site":  "propart-directory",
                    "public":  ".",
                    "ignore":  [
                                   "firebase.json",
                                   "**/.git/**",
                                   "**/node_modules/**",
                                   "**/*.md",
                                   "**/docs/**",
                                   "**/private/**",
                                   "**/*HANDOFF*",
                                   "**/*WHITEPAPER*",
                                   "**/*WAKE-UP*",
                                   "**/*EMERGENCY*",
                                   "**/*CREDENTIAL*",
                                   "**/*OWNER*INPUT*",
                                   "**/*INCIDENT*",
                                   "**/*PLAYBOOK*",
                                   "**/OWNER-NOTES*",
                                   "**/.well-known/test-workflows.json"
                               ],
                    "headers":  [
                                    {
                                        "headers":  [
                                                        {
                                                            "key":  "X-Robots-Tag",
                                                            "value":  "noindex, nofollow, noai, noimageai"
                                                        },
                                                        {
                                                            "key":  "X-Content-Type-Options",
                                                            "value":  "nosniff"
                                                        }
                                                    ],
                                        "source":  "**/*.md"
                                    },
                                    {
                                        "source":  "**",
                                        "headers":  [
                                                        {
                                                            "key":  "X-Content-Type-Options",
                                                            "value":  "nosniff"
                                                        },
                                                        {
                                                            "key":  "Referrer-Policy",
                                                            "value":  "strict-origin-when-cross-origin"
                                                        },
                                                        {
                                                            "key":  "X-Robots-Tag",
                                                            "value":  "noai, noimageai"
                                                        },
                                                        {
                                                            "key":  "X-Enterprise-Licensing",
                                                            "value":  "https://www.propart.app/enterprise.html"
                                                        },
                                                        {
                                                            "key":  "Strict-Transport-Security",
                                                            "value":  "max-age=31536000; includeSubDomains"
                                                        },
                                                        {
                                                            "key":  "Content-Security-Policy",
                                                            "value":  "object-src \u0027none\u0027; base-uri \u0027self\u0027; frame-ancestors \u0027self\u0027; upgrade-insecure-requests"
                                                        },
                                                        {
                                                            "key":  "Permissions-Policy",
                                                            "value":  "camera=(), microphone=(), geolocation=(), payment=()"
                                                        },
                                                        {
                                                            "key":  "X-Frame-Options",
                                                            "value":  "SAMEORIGIN"
                                                        }
                                                    ]
                                    }
                                ],
                    "redirects":  [
                                      {
                                          "source":  "/studio",
                                          "destination":  "/Studio",
                                          "type":  301
                                      },
                                      {
                                          "source":  "/creator",
                                          "destination":  "https://propart-creator.web.app/",
                                          "type":  301
                                      },
                                      {
                                          "source":  "/pod",
                                          "destination":  "/POD",
                                          "type":  301
                                      },
                                      {
                                          "source":  "/cardart",
                                          "destination":  "/POD",
                                          "type":  301
                                      },
                                      {
                                          "source":  "/blend",
                                          "destination":  "/BlendVisualizer",
                                          "type":  301
                                      },
                                      {
                                          "source":  "/cane",
                                          "destination":  "/CaneDesigner",
                                          "type":  301
                                      },
                                      {
                                          "source":  "/cropper",
                                          "destination":  "/CropperTool",
                                          "type":  301
                                      },
                                      {
                                          "source":  "/Hub",
                                          "destination":  "https://propart-creator.web.app/",
                                          "type":  301
                                      },
                                      {
                                          "source":  "/Hub/**",
                                          "destination":  "https://propart-creator.web.app/",
                                          "type":  301
                                      },
                                      {
                                          "source":  "/blendvisualizer",
                                          "destination":  "/BlendVisualizer",
                                          "type":  301
                                      },
                                      {
                                          "source":  "/canedesigner",
                                          "destination":  "/CaneDesigner",
                                          "type":  301
                                      },
                                      {
                                          "source":  "/croppertool",
                                          "destination":  "/CropperTool",
                                          "type":  301
                                      }
                                  ],
                    "rewrites":  [
                                     {
                                         "source":  "/api/createCheckoutSession",
                                         "function":  "createCheckoutSession"
                                     },
                                     {
                                         "source":  "/api/getDigitalDownloadUrl",
                                         "function":  "getDigitalDownloadUrl"
                                     },
                                     {
                                         "source":  "/api/submitSiteContact",
                                         "function":  "submitSiteContact"
                                     },
                                     {
                                         "source":  "/api/stripeWebhook",
                                         "function":  "stripeWebhook"
                                     },
                                     {
                                         "source":  "/Studio",
                                         "destination":  "/Studio/index.html"
                                     },
                                     {
                                         "source":  "/POD",
                                         "destination":  "/POD/index.html"
                                     },
                                     {
                                         "source":  "/BlendVisualizer",
                                         "destination":  "/BlendVisualizer/index.html"
                                     },
                                     {
                                         "source":  "/CaneDesigner",
                                         "destination":  "/CaneDesigner/index.html"
                                     },
                                     {
                                         "source":  "/CropperTool",
                                         "destination":  "/CropperTool/index.html"
                                     }
                                 ]
                }
}
